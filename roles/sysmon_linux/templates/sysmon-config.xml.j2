<Sysmon schemaversion="4.90">
  <EventFiltering>

    <!-- Event ID 1 - ProcessCreate -->
    <ProcessCreate onmatch="exclude">
      <Image condition="end with">/usr/sbin/cron</Image>
      <Image condition="end with">/usr/sbin/crond</Image>
      <Image condition="end with">/usr/bin/monit</Image>
      <Image condition="end with">/opt/splunkforwarder/bin/splunkd</Image>
      <Image condition="end with">/usr/lib/systemd/systemd-journald</Image>
      <Image condition="end with">/usr/bin/dbus-daemon</Image>
      <!-- nginx process creation izlenmeyecek -->
      <Image condition="end with">/usr/sbin/nginx</Image>
      <CommandLine condition="contains">ansible-playbook</CommandLine>
    </ProcessCreate>

    <!-- Event ID 3 - NetworkConnect -->
    <NetworkConnect onmatch="exclude">
      <!-- Loopback trafiği -->
      <SourceIp condition="is">127.0.0.1</SourceIp>
      <SourceIp condition="is">::1</SourceIp>
      <DestinationIp condition="is">127.0.0.1</DestinationIp>
      <DestinationIp condition="is">::1</DestinationIp>
      <!-- systemd-resolved stub resolver (127.0.0.53) üzerinden gelen DNS trafiği -->
      <SourceIp condition="is">127.0.0.53</SourceIp>
      <DestinationIp condition="is">127.0.0.53</DestinationIp>
      <!-- İç ağ hedefleri — izlenmeyecek (sysmon_excluded_destination_ips) -->
{% for ip in sysmon_excluded_destination_ips %}
      <DestinationIp condition="is">{{ ip }}</DestinationIp>
{% endfor %}
      <!-- Gürültülü process'ler — tüm network bağlantıları izlenmeyecek (sysmon_excluded_network_images) -->
{% for image in sysmon_excluded_network_images %}
      <Image condition="end with">{{ image }}</Image>
{% endfor %}
    </NetworkConnect>

    <!-- Event ID 5 - ProcessTerminate -->
    <!-- Linux'ta tüm binary path'ler / ile başlar; catch-all exclude ile tamamen susturulur.
         onmatch="include" + boş bırakmak Sysmon for Linux'ta olayları susturmaz. -->
    <ProcessTerminate onmatch="exclude">
      <Image condition="begin with">/</Image>
    </ProcessTerminate>

    <!-- Event ID 9 - RawAccessRead -->
    <!-- Linux'ta düşük değerli, devre dışı -->
    <RawAccessRead onmatch="exclude">
      <Image condition="begin with">/</Image>
    </RawAccessRead>

    <!-- Event ID 11 - FileCreate -->
    <FileCreate onmatch="include">
      <TargetFilename condition="begin with">/etc/</TargetFilename>
      <TargetFilename condition="begin with">/boot/</TargetFilename>
      <TargetFilename condition="begin with">/usr/local/bin/</TargetFilename>
      <TargetFilename condition="begin with">/usr/bin/</TargetFilename>
      <TargetFilename condition="begin with">/usr/sbin/</TargetFilename>
      <TargetFilename condition="contains">/var/www/</TargetFilename>
    </FileCreate>

    <!-- Event ID 23 - FileDelete -->
    <FileDelete onmatch="include">
      <TargetFilename condition="begin with">/etc/</TargetFilename>
      <TargetFilename condition="begin with">/boot/</TargetFilename>
      <TargetFilename condition="contains">/var/www/</TargetFilename>
      <TargetFilename condition="contains">/var/log/</TargetFilename>
    </FileDelete>

  </EventFiltering>
</Sysmon>
