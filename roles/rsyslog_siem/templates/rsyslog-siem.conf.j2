# Gerekli modüller
module(load="imfile")

# ─────────────────────────────────────────────
# GÖNDERİM KURALI (Ruleset)
# Hem auditd hem de sysmon bu ruleset'i kullanır.
# "stop" direktifi: iletim sonrası mesaj yerel dosyalara yazılmaz.
# ─────────────────────────────────────────────
ruleset(name="SendToSIEM") {
    action(
        type="omfwd"
        target="{{ siem_host }}"
        port="{{ siem_port }}"
        protocol="{{ siem_protocol }}"
        template="RSYSLOG_ForwardFormat"
        queue.type="LinkedList"
        queue.filename="siem_queue"
        queue.maxdiskspace="{{ rsyslog_queue_maxchk }}"
        queue.saveonshutdown="on"
        action.resumeRetryCount="-1"
    )
    stop
}

# ─────────────────────────────────────────────
# AUDITD LOGLARINI OKU VE GÖNDER
# ─────────────────────────────────────────────
input(type="imfile"
      File="/var/log/audit/audit.log"
      Tag="auditd"
      Ruleset="SendToSIEM"
      freshStartTail="off"
)

# ─────────────────────────────────────────────
# SYSMON LOGLARINI OKU VE GÖNDER
#
# Sysmon servisi artık journald yerine doğrudan bu dosyaya yazar
# (sysmon.service StandardOutput=append:{{ sysmon_log_path }}).
# imfile ile okuyup SIEM'e iletiyoruz; "stop" sayesinde başka
# hiçbir yerel dosyaya yazılmıyor — disk üzerinde kalıntı kalmaz.
# ─────────────────────────────────────────────
input(type="imfile"
      File="{{ sysmon_log_path }}"
      Tag="sysmon"
      Ruleset="SendToSIEM"
      freshStartTail="off"
)
